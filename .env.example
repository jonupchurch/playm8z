# Copy this file to .env.local and fill in real values. .env.local is
# gitignored; this file is the only env file that's committed.

# Postgres connection string used by Drizzle (src/db/index.ts) and
# drizzle-kit (drizzle.config.ts). Local dev example:
# postgres://<user>:<password>@localhost:5432/playm8z
DATABASE_URL=

# Auth.js. Generate a secret with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Google OAuth provider -- create credentials at
# https://console.cloud.google.com/apis/credentials
# (Authorized redirect URI: http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (transactional email -- verification emails). Optional: when
# unset, src/lib/email/send-verification-email.ts logs the verification
# link to the server console instead of sending a real email. Provisioning
# is blocked on owning a domain (Resend requires one); see
# specs/001-auth-onboarding/research.md #1.
# RESEND_API_KEY=
# EMAIL_FROM=
