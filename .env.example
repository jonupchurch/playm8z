# Copy this file to .env.local and fill in real values. .env.local is
# gitignored; this file is the only env file that's committed.

# Postgres connection string used by Drizzle (src/db/index.ts) and
# drizzle-kit (drizzle.config.ts). Local dev example:
# postgres://<user>:<password>@localhost:5432/playm8z
DATABASE_URL=

# Auth.js. Generate a secret with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Google OAuth provider -- create credentials at
# https://console.cloud.google.com/apis/credentials
# (Authorized redirect URI: http://localhost:3000/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# The site's canonical absolute URL, used to build links that go OUT in an
# email and come back (src/lib/email/app-url.ts). Leave unset locally --
# it falls back to http://localhost:3000, which is what you want. It is set
# for real in Vercel, and it MUST be: a wrong value here is invisible in
# every test and every local run, and only shows up as a dead link in a
# user's inbox. (That is not hypothetical -- the old code read a
# NEXTAUTH_URL that was never set anywhere, so every link it built pointed
# at localhost. Fixed 2026-07-16.)
# APP_URL=

# Resend (transactional email -- verification, password reset). Provisioned
# 2026-07-16 via `vercel integration add resend/resend-email` on the domain
# send.playm8z.net; both vars below are set automatically by that
# integration in Vercel, so you only need them here if you want a local run
# to send real mail.
#
# Optional: when RESEND_API_KEY is unset, src/lib/email/send-email.ts logs
# the message to the server console instead of sending -- which is how local
# dev, CI, and unit tests exercise these flows without a secret. (The one
# exception: an unset key in *production* is a real misconfiguration and is
# logged as an error rather than quietly swallowed.)
#
# RESEND_EMAIL_DOMAIN is the *verified* sending domain. The sender is
# derived from it (noreply@<domain>) because Resend 403s unless the from-
# domain matches a verified domain exactly. EMAIL_FROM overrides that
# derivation -- if you set it, keeping it on the verified domain is on you.
# RESEND_API_KEY=
# RESEND_EMAIL_DOMAIN=
# EMAIL_FROM=

# Vercel AI Gateway (Admin-only AI writing assist, feature 028) -- get a
# key at https://vercel.com/[team]/~/ai-gateway/api-keys. Required for
# generate-news-draft.ts/generate-content-page-draft.ts/improve-draft-text.ts
# to actually reach Claude Haiku; Vitest mocks the `ai` package entirely,
# so unit tests need no real value (specs/028-ai-writing-assist/research.md #7).
AI_GATEWAY_API_KEY=

# Vercel Blob (News cover image upload, feature 029) -- get a
# read-write token at https://vercel.com/[team]/~/stores. Required for
# upload-news-cover-image.ts to actually store a file; Vitest mocks
# `@vercel/blob` entirely, so unit tests need no real value
# (specs/029-news-cover-image-upload/research.md #5).
BLOB_READ_WRITE_TOKEN=
