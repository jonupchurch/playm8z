# Speckit files (.specify/, .claude/) are intentionally NOT ignored --
# they're part of the repo's process narrative. The one exception is
# settings.local.json, Claude Code's own convention for machine-local
# permissions/paths that were never meant to be shared.
.claude/settings.local.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# testing (vitest coverage, playwright artifacts)
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel
.vercel

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env*
!.env.example

# OS files
.DS_Store
Thumbs.db
*.pem
